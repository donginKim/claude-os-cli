{
  "name": "claude-os",
  "version": "0.1.0",
  "description": "Context version control for Claude Code — turn your PC into a Claude OS",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "claude-os": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "lint": "eslint src/",
    "test": "node --test dist/**/*.test.js"
  },
  "keywords": [
    "claude",
    "claude-code",
    "context-management",
    "harness",
    "ai-tools"
  ],
  "license": "MIT",
  "dependencies": {
    "blessed": "^0.1.81",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "diff": "^7.0.0",
    "glob": "^11.0.0"
  },
  "devDependencies": {
    "@types/blessed": "^0.1.25",
    "@types/diff": "^7.0.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
